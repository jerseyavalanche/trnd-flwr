{$TRND_DOMAIN} {
  encode gzip

  handle /api/* {
    reverse_proxy trnd-backend:{$TRND_PORT}
  }

  handle_path /n8n/* {
    reverse_proxy n8n:5678
  }

  handle_path /status/* {
    reverse_proxy uptime-kuma:3001
  }

  handle_path /grafana/* {
    reverse_proxy grafana:3000
  }

  handle {
    reverse_proxy trnd-frontend:5173
  }
}
